<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Portfolio de développeur - Technologies modernes et projets innovants">
    <meta name="keywords" content="développeur, portfolio, web, javascript, frontend">
    <meta name="author" content="Portfolio Owner">
    
    <!-- Open Graph -->
    <meta property="og:title" content="Portfolio - Développeur Web">
    <meta property="og:description" content="Découvrez mes projets et compétences en développement web">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://monportfolio.com">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <title>Portfolio - Développeur Web</title>
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/themes.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/glassmorphism.css">
    <link rel="stylesheet" href="/css/animations.css">
    <link rel="stylesheet" href="/css/hero-animations.css">
    <link rel="stylesheet" href="/css/about-section.css">
    <link rel="stylesheet" href="/css/contact-form.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h2 class="floating">Portfolio</h2>
            </div>
            <div class="nav-menu">
                <a href="#hero" class="nav-link">Accueil</a>
                <a href="#about" class="nav-link">À propos</a>
                <a href="#projects" class="nav-link">Projets</a>
                <a href="#contact" class="nav-link">Contact</a>
                <button class="theme-toggle animate-hover" aria-label="Basculer le thème">🌙</button>
            </div>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="hero" class="hero">
        <div class="hero-content glass-card">
            <h1 class="hero-title staggered-text">Bonjour, je suis Développeur Full Stack</h1>
            <p class="hero-description" data-typewriter="Passionné par les technologies web modernes et l'innovation" data-speed="60">Passionné par les technologies web modernes et l'innovation</p>
            <div class="hero-actions">
                <a href="#projects" class="btn btn-primary animate-hover">
                    <span>Voir mes projets</span>
                </a>
                <a href="#contact" class="btn btn-secondary animate-hover">
                    <span>Me contacter</span>
                </a>
            </div>
        </div>
        <div class="hero-background parallax-element">
            <div class="floating-shapes">
                <div class="shape shape-1 morphing-shape floating"></div>
                <div class="shape shape-2 morphing-shape rotating"></div>
                <div class="shape shape-3 morphing-shape floating"></div>
                <div class="shape shape-4 morphing-shape"></div>
                <div class="shape shape-5 morphing-shape floating"></div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title animate-on-scroll">À propos de moi</h2>
            <div class="about-content glass-card animate-on-scroll">
                <!-- Content will be populated dynamically by about-section.js -->
                <div class="about-text">
                    <p class="animate-on-scroll">Chargement des données...</p>
                    <div class="about-stats animate-on-scroll">
                        <div class="stat-item">
                            <div class="stat-number" data-counter="50">0</div>
                            <div class="stat-label">Projets réalisés</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" data-counter="5">0</div>
                            <div class="stat-label">Années d'expérience</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-number" data-counter="20">0</div>
                            <div class="stat-label">Technologies maîtrisées</div>
                        </div>
                    </div>
                    <div class="skills-preview" id="skills-container">
                        <span class="skill-tag animate-on-scroll">JavaScript</span>
                        <span class="skill-tag animate-on-scroll">React</span>
                        <span class="skill-tag animate-on-scroll">Node.js</span>
                        <span class="skill-tag animate-on-scroll">CSS3</span>
                        <span class="skill-tag animate-on-scroll">TypeScript</span>
                        <span class="skill-tag animate-on-scroll">Vue.js</span>
                    </div>
                    <div class="skills-bars animate-on-scroll">
                        <div class="skill-item">
                            <div class="skill-name">JavaScript</div>
                            <div class="skill-bar">
                                <div class="skill-progress" data-progress="90%"></div>
                            </div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-name">React</div>
                            <div class="skill-bar">
                                <div class="skill-progress" data-progress="85%"></div>
                            </div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-name">Node.js</div>
                            <div class="skill-bar">
                                <div class="skill-progress" data-progress="80%"></div>
                            </div>
                        </div>
                        <div class="skill-item">
                            <div class="skill-name">CSS3</div>
                            <div class="skill-bar">
                                <div class="skill-progress" data-progress="95%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects">
        <div class="container">
            <h2 class="section-title animate-on-scroll">Mes Projets</h2>
            <div class="project-filters animate-on-scroll">
                <button class="filter-btn active animate-hover" data-filter="all">Tous</button>
                <button class="filter-btn animate-hover" data-filter="web">Web</button>
                <button class="filter-btn animate-hover" data-filter="mobile">Mobile</button>
                <button class="filter-btn animate-hover" data-filter="api">API</button>
            </div>
            <div class="projects-grid" id="projects-grid">
                <!-- Projects will be loaded dynamically -->
                <div class="project-card glass-card animate-on-scroll animate-hover will-animate" data-category="web">
                    <div class="project-image">
                        <div class="placeholder-image">📱</div>
                    </div>
                    <div class="project-content">
                        <h3 class="project-title">Projet Demo</h3>
                        <p class="project-description">Description du projet de démonstration avec animations avancées</p>
                        <div class="project-tech">
                            <span class="tech-tag">HTML</span>
                            <span class="tech-tag">CSS</span>
                            <span class="tech-tag">JavaScript</span>
                            <span class="tech-tag">Vite</span>
                        </div>
                        <div class="project-links">
                            <a href="#" class="project-link animate-hover">Demo</a>
                            <a href="#" class="project-link animate-hover">Code</a>
                        </div>
                    </div>
                </div>
                <div class="project-card glass-card animate-on-scroll animate-hover will-animate" data-category="web">
                    <div class="project-image">
                        <div class="placeholder-image">⚛️</div>
                    </div>
                    <div class="project-content">
                        <h3 class="project-title">App React</h3>
                        <p class="project-description">Application React moderne avec hooks et context</p>
                        <div class="project-tech">
                            <span class="tech-tag">React</span>
                            <span class="tech-tag">TypeScript</span>
                            <span class="tech-tag">Styled Components</span>
                        </div>
                        <div class="project-links">
                            <a href="#" class="project-link animate-hover">Demo</a>
                            <a href="#" class="project-link animate-hover">Code</a>
                        </div>
                    </div>
                </div>
                <div class="project-card glass-card animate-on-scroll animate-hover will-animate" data-category="api">
                    <div class="project-image">
                        <div class="placeholder-image">🚀</div>
                    </div>
                    <div class="project-content">
                        <h3 class="project-title">API Node.js</h3>
                        <p class="project-description">API RESTful avec Express et MongoDB</p>
                        <div class="project-tech">
                            <span class="tech-tag">Node.js</span>
                            <span class="tech-tag">Express</span>
                            <span class="tech-tag">MongoDB</span>
                            <span class="tech-tag">JWT</span>
                        </div>
                        <div class="project-links">
                            <a href="#" class="project-link animate-hover">Demo</a>
                            <a href="#" class="project-link animate-hover">Code</a>
                        </div>
                    </div>
                </div>
                <div class="project-card glass-card animate-on-scroll animate-hover will-animate" data-category="mobile">
                    <div class="project-image">
                        <div class="placeholder-image">📱</div>
                    </div>
                    <div class="project-content">
                        <h3 class="project-title">App Mobile</h3>
                        <p class="project-description">Application mobile native avec React Native</p>
                        <div class="project-tech">
                            <span class="tech-tag">React Native</span>
                            <span class="tech-tag">Redux</span>
                            <span class="tech-tag">Firebase</span>
                        </div>
                        <div class="project-links">
                            <a href="#" class="project-link animate-hover">Demo</a>
                            <a href="#" class="project-link animate-hover">Code</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2 class="section-title animate-on-scroll">Contactez-moi</h2>
            <div class="contact-content">
                <div class="contact-info glass-card animate-on-scroll">
                    <h3>Discutons de votre projet</h3>
                    <p>Je suis toujours intéressé par de nouveaux défis et collaborations.</p>
                    <div class="contact-methods">
                        <div class="contact-method animate-on-scroll">
                            <span class="contact-icon">📧</span>
                            <span>contact@portfolio.com</span>
                        </div>
                        <div class="contact-method animate-on-scroll">
                            <span class="contact-icon">💼</span>
                            <span>LinkedIn</span>
                        </div>
                        <div class="contact-method animate-on-scroll">
                            <span class="contact-icon">📱</span>
                            <span>+33 1 23 45 67 89</span>
                        </div>
                    </div>
                </div>
                <form class="contact-form glass-card animate-on-scroll" id="contact-form" novalidate>
                    <div class="form-group">
                        <label for="name">Nom complet *</label>
                        <input 
                            type="text" 
                            id="name" 
                            name="name" 
                            required 
                            autocomplete="name"
                            aria-describedby="name-error"
                            minlength="2"
                            maxlength="50"
                            placeholder="Votre nom complet">
                    </div>
                    <div class="form-group">
                        <label for="email">Adresse email *</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            required 
                            autocomplete="email"
                            aria-describedby="email-error"
                            placeholder="votre@email.com">
                    </div>
                    <div class="form-group">
                        <label for="message">Message *</label>
                        <textarea 
                            id="message" 
                            name="message" 
                            required 
                            rows="5" 
                            minlength="10"
                            maxlength="1000"
                            placeholder="Décrivez votre projet ou votre demande..."></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary animate-hover">
                            <span>Envoyer le message</span>
                        </button>
                        <button type="reset" class="btn animate-hover">
                            <span>Effacer</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p class="animate-on-scroll">&copy; 2024 Portfolio. Fait avec ❤️ et du code propre.</p>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/theme-toggle.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/animations.js"></script>
    <script src="/js/hero-animations.js"></script>
    <script src="/js/about-section.js"></script>
    <script src="/js/project-filter.js"></script>
    <script src="/js/contact-form.js"></script>
</body>
</html>