{
  "name": "portfolio-minimal",
  "version": "1.0.0",
  "description": "Portfolio minimal avec Vite.js et glassmorphism",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "docker:build": "chmod +x scripts/docker-build.sh && ./scripts/docker-build.sh",
    "docker:validate": "chmod +x scripts/validate-docker.sh && ./scripts/validate-docker.sh",
    "docker:deploy": "chmod +x scripts/deploy.sh && ./scripts/deploy.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker system prune -f && docker image prune -f"
  },
  "dependencies": {
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "vite": "^5.4.21"
  },
  "keywords": [
    "portfolio",
    "vite",
    "glassmorphism",
    "vanilla-js",
    "docker",
    "production-ready"
  ],
  "author": "Portfolio Owner",
  "license": "MIT",
  "main": "vite.config.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/portfolio-minimal.git"
  },
  "homepage": "https://yourdomain.com",
  "bugs": {
    "url": "https://github.com/yourusername/portfolio-minimal/issues"
  }
}